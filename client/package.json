{
  "name": "epoch-dash-client",
  "version": "1.0.0",
  "description": "Epoch Dash - Desktop Client",
  "repository": "https://github.com/CorvidoKloo/epochdash",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "form-data": "^4.0.0",
    "jimp": "^1.6.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "author": "Epoch Dash Team",
  "build": {
    "appId": "com.epochdash.app",
    "productName": "Epoch Dash",
    "files": [
      "**/*",
      "!**/*.map"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
