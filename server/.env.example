# ----------------------------------------------------
# Epoch Dash - Environment Configuration
# ----------------------------------------------------

# Server Config
PORT=3847

# Secret Key for JWT Authentication (Change this to a long random string!)
JWT_SECRET=super_secret_jwt_key_epoch_dash_123!

# Database
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/epochdash

# Cloud Storage (AWS S3, Cloudflare R2, MinIO, etc.)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=epoch-dash-screenshots
#AWS_ENDPOINT=https://your-account.r2.cloudflarestorage.com # Optional, used for R2/MinIO
#AWS_FORCE_PATH_STYLE=true # Optional, set true for MinIO locally
